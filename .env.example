# Environment variables for thesis-agents-python.
# Copy to .env (gitignored) and fill in real values. config.py reads these
# with safe defaults; required secrets have NO default and fail loudly if unset.
# Document every variable here (names only — never commit real values).

# --- Required secret (NO default; config.py fails loudly if unset) ---
# OPENROUTER_API_KEY=

# --- Optional overrides (config.py supplies safe defaults) ---
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# OPENROUTER_MODEL_PRO=deepseek/deepseek-v4-pro
# OPENROUTER_MODEL_FLASH=deepseek/deepseek-v4-flash
# REQUEST_TIMEOUT_S=120
# MAX_TURNS=6
# MAX_REVIEW_PASSES=2
# MAX_JUDGE_RETRIES=2
# DATA_DIR=data
